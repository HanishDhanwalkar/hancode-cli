# Local agentic starter environment

# Where this project stores local state, logs, and session archives.
AGENTIC_HOME=C:\Users\YourName\.agentic_hints

# Ollama server base URL for local model access.
# The code expects an OpenAI-compatible root and will append /v1 when needed.
OLLAMA_HOST=http://localhost:11434

# Default local model name used when no model is passed explicitly.
OLLAMA_MODEL=llama3.2

# Optional: set if your local OpenAI-compatible endpoint expects a bearer token.
OLLAMA_API_KEY=
